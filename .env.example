# ── Model Configuration ──
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# OpenAI / OpenAI-compatible (DashScope, Ollama, etc.)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (set LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (set LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# ── Agent Settings ──
DEFAULT_AGENT_MODE=build     # build | plan
MAX_TOOL_ITERATIONS=50
TOOL_TIMEOUT_SECONDS=120

# ── Storage ──
CHECKPOINT_DB=~/.opencode-deepagents/checkpoints.db

# ── Experimental ──
# OPENCODE_EXPERIMENTAL_LSP_TOOL=1
