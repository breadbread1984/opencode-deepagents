# ── Model Configuration ──
# Supported providers: dashscope (default), openai, anthropic, ollama
LLM_PROVIDER=dashscope
LLM_MODEL=qwen3.6-plus

# DashScope (default provider)
DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1  # default

# OpenAI (set LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (set LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (set LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# ── Agent Settings ──
DEFAULT_AGENT_MODE=build     # build | plan
MAX_TOOL_ITERATIONS=50
TOOL_TIMEOUT_SECONDS=120

# ── Storage ──
CHECKPOINT_DB=~/.opencode-deepagents/checkpoints.db

# ── Experimental ──
# OPENCODE_EXPERIMENTAL_LSP_TOOL=1

# ── Observability (LangSmith) ──
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_...
# LANGCHAIN_PROJECT=opencode-deepagents
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # or self-hosted URL
